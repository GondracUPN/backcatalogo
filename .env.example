DATABASE_URL=postgres://user:password@localhost:5432/mydb
SESSION_SECRET=change-me-session-secret
JWT_SECRET=change-me-jwt-secret
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-admin-password
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100

# Sync + Revalidation
SYNC_SECRET=change-me-too
NEXT_BASE_URL=http://127.0.0.1:3000
CATALOG_SYNC_URL=http://127.0.0.1:3001/api/sync/product

# Upstream pull (optional) - manual/admin sync
UPSTREAM_API_BASE=http://127.0.0.1:3101
UPSTREAM_CATALOG_PATH=/catalog
UPSTREAM_STAGED_PATH=/admin/staged
# Optional auth
UPSTREAM_API_TOKEN=
UPSTREAM_AUTH_HEADER=Authorization
UPSTREAM_API_KEY=
# Set to 0 to disable upstream sync jobs
UPSTREAM_SYNC_ON_READ=1
